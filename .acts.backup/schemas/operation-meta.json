{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://acts-standard.org/schemas/operation-meta/v0.3.0",
  "title": "ACTS Operation Metadata",
  "description": "Schema for the YAML frontmatter block in .acts/operations/*.md files.",
  "type": "object",
  "required": [
    "operation_id",
    "layer",
    "required",
    "triggers",
    "context_budget",
    "required_inputs",
    "preconditions",
    "postconditions"
  ],
  "additionalProperties": false,
  "properties": {
    "operation_id": {
      "type": "string",
      "description": "Unique operation identifier. MUST match the filename (without .md).",
      "pattern": "^[a-z][a-z0-9-]*$",
      "examples": ["preflight", "session-summary", "story-init"]
    },
    "layer": {
      "type": "integer",
      "enum": [1, 2, 3, 4, 5],
      "description": "ACTS layer this operation belongs to."
    },
    "required": {
      "type": "boolean",
      "description": "Whether this operation is required for ACTS Standard conformance."
    },
    "triggers": {
      "type": "string",
      "description": "State transition this operation triggers, or 'none'.",
      "examples": [
        "APPROVED → IN_PROGRESS (first run only)",
        "IN_PROGRESS → REVIEW",
        "none",
        "(none) → ANALYSIS"
      ]
    },
    "context_budget": {
      "type": "integer",
      "minimum": 1000,
      "description": "Maximum tokens for context ingestion in this operation."
    },
    "required_inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/input" },
      "description": "Inputs that MUST be provided."
    },
    "optional_inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/input" },
      "description": "Inputs that MAY be provided."
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Conditions that MUST be true before execution."
    },
    "postconditions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Conditions that MUST be true after execution."
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": ["name", "type", "required"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Input parameter name.",
          "pattern": "^[a-z_][a-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["string", "integer", "boolean"],
          "description": "Input parameter type."
        },
        "required": {
          "type": "boolean",
          "description": "Whether this input is required."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the input."
        },
        "validation": {
          "type": "string",
          "description": "Regex pattern for input validation."
        },
        "default": {
          "description": "Default value if not provided."
        }
      }
    }
  }
}
