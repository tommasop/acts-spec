#!/usr/bin/env bash
# acts-update — Update ACTS framework files from GitHub with backup
# Usage:
#   acts-update --check           Check for available updates from GitHub
#   acts-update --dry-run         Show what would change (diff)
#   acts-update                   Apply update from GitHub (backup + download + apply)
#   acts-update --force           Force update even if version matches (re-apply framework files)
#   acts-update --restore v0.6.0  Restore from backup

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ACTS_DIR="$(dirname "$SCRIPT_DIR")"
PROJECT_ROOT="$(dirname "$ACTS_DIR")"
ACTS_JSON="$ACTS_DIR/acts.json"
BACKUP_DIR="$ACTS_DIR/backup"
TEMP_DIR=""

# GitHub repository info
GITHUB_REPO="tommasop/acts-spec"
GITHUB_RAW_URL="https://raw.githubusercontent.com/$GITHUB_REPO"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Helpers ────────────────────────────────────────────────────────────

log_info()  { echo -e "${BLUE}ℹ${NC} $1"; }
log_warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }
log_ok()    { echo -e "${GREEN}✓${NC} $1"; }
log_bold()  { echo -e "${BOLD}$1${NC}"; }

cleanup() {
    if [[ -n "$TEMP_DIR" && -d "$TEMP_DIR" ]]; then
        rm -rf "$TEMP_DIR"
    fi
}
trap cleanup EXIT

get_current_version() {
    if [[ -f "$ACTS_JSON" ]]; then
        python3 -c "
import json, sys
with open('$ACTS_JSON') as f:
    data = json.load(f)
print(data.get('manifest_version', 'unknown'))
" 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

get_latest_version_from_github() {
    # Download the latest spec file list from GitHub
    local temp_dir=$(mktemp -d)
    local latest_version="unknown"
    
    # Try to get the latest release tag first
    local latest_tag
    latest_tag=$(curl -s --max-time 10 "https://api.github.com/repos/$GITHUB_REPO/releases/latest" 2>/dev/null | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    tag = data.get('tag_name', '').lstrip('v')
    print(tag)
except:
    pass
" 2>/dev/null)
    
    if [[ -n "$latest_tag" && "$latest_tag" != "null" ]]; then
        echo "$latest_tag"
        rm -rf "$temp_dir"
        return
    fi
    
    # Fallback: try to download from main branch and detect version from spec file
    for branch in main master; do
        local spec_list_url="$GITHUB_RAW_URL/$branch/"
        # Download directory listing (GitHub doesn't provide this easily, so we try common versions)
        for version in 0.6.2 0.6.1 0.6.0 0.5.0; do
            local spec_url="$GITHUB_RAW_URL/$branch/acts-v${version}.md"
            if curl -s --max-time 5 --head "$spec_url" 2>/dev/null | grep -q "200 OK"; then
                latest_version="$version"
            fi
        done
        if [[ "$latest_version" != "unknown" ]]; then
            break
        fi
    done
    
    rm -rf "$temp_dir"
    echo "$latest_version"
}

download_latest_from_github() {
    local target_dir="$1"
    local downloaded_version=""
    
    log_info "Downloading latest ACTS from GitHub..."
    
    for branch in main master; do
        local tarball_url="https://github.com/$GITHUB_REPO/archive/refs/heads/$branch.tar.gz"
        local temp_tar=$(mktemp)
        
        if curl -L -s --max-time 30 "$tarball_url" -o "$temp_tar" 2>/dev/null; then
            local extract_dir=$(mktemp -d)
            if tar -xzf "$temp_tar" -C "$extract_dir" 2>/dev/null; then
                local source_dir=$(ls -d "$extract_dir"/* | head -1)
                if [[ -d "$source_dir/.acts" ]]; then
                    # Detect version from spec file
                    local spec_file=$(ls -1 "$source_dir"/acts-v*.md 2>/dev/null | sort -V | tail -n1)
                    if [[ -n "$spec_file" ]]; then
                        downloaded_version=$(basename "$spec_file" | sed 's/acts-v\(.*\)\.md/\1/')
                        
                        # Copy framework files to target
                        cp -r "$source_dir/.acts" "$target_dir/acts-download"
                        mv "$target_dir/acts-download" "$target_dir/.acts"
                        
                        log_ok "Downloaded ACTS v$downloaded_version from GitHub"
                        rm -rf "$extract_dir" "$temp_tar"
                        echo "$downloaded_version"
                        return 0
                    fi
                fi
            fi
            rm -rf "$extract_dir"
        fi
        rm -f "$temp_tar"
    done
    
    log_error "Failed to download ACTS from GitHub"
    return 1
}

version_compare() {
    # Returns: 0 if equal, 1 if $1 < $2, 2 if $1 > $2
    local v1="$1" v2="$2"
    if [[ "$v1" == "$v2" ]]; then
        return 0
    fi
    local IFS='.'
    local -a a=($v1) b=($v2)
    for i in 0 1 2; do
        local ai="${a[i]:-0}" bi="${b[i]:-0}"
        if (( ai < bi )); then return 1; fi
        if (( ai > bi )); then return 2; fi
    done
    return 0
}

# ─── Commands ───────────────────────────────────────────────────────────

cmd_check() {
    local current latest
    current=$(get_current_version)
    log_info "Checking GitHub for latest version..."
    latest=$(get_latest_version_from_github)
    
    log_bold "ACTS Update Check"
    echo "  Current version: $current"
    echo "  Latest version:  $latest"
    echo ""
    
    if [[ "$latest" == "unknown" ]]; then
        log_error "Could not determine latest version from GitHub"
        exit 1
    fi
    
    if version_compare "$current" "$latest"; then
        log_ok "Already up to date (v$current)"
    else
        log_warn "Update available: v$current → v$latest"
        echo "  Run: .acts/bin/acts-update --dry-run"
    fi
}

cmd_dry_run() {
    local current latest
    current=$(get_current_version)
    log_info "Checking GitHub for latest version..."
    latest=$(get_latest_version_from_github)
    
    if [[ "$latest" == "unknown" ]]; then
        log_error "Could not determine latest version from GitHub"
        exit 1
    fi
    
    log_bold "ACTS Update Dry Run (v$current → v$latest)"
    echo ""
    
    # Framework files to update
    local framework_files=(
        "operations"
        "schemas"
        "report-protocol.md"
        "code-review-interface.json"
    )
    
    log_info "Files that would be updated from GitHub:"
    for item in "${framework_files[@]}"; do
        local target="$ACTS_DIR/$item"
        if [[ -d "$target" ]]; then
            local count
            count=$(find "$target" -type f | wc -l)
            echo "  .acts/$item/ ($count files)"
        elif [[ -f "$target" ]]; then
            echo "  .acts/$item"
        fi
    done
    
    echo ""
    log_info "Config merge preview:"
    echo "  manifest_version: $current → $latest (will update)"
    echo "  All other fields: preserved (project-specific)"
    
    echo ""
    log_info "Files that will be preserved:"
    echo "  .acts/acts.json (merged)"
    echo "  .acts/review-providers/ (preserved)"
    echo "  .acts/adapters/ (preserved)"
    echo "  .story/ (untouched)"
    echo "  AGENTS.md (untouched)"
}

cmd_update() {
    local current latest force="$1"
    current=$(get_current_version)
    
    log_info "Fetching latest version from GitHub..."
    
    # Create temp dir for downloading
    TEMP_DIR=$(mktemp -d)
    
    # Download latest from GitHub
    if ! latest=$(download_latest_from_github "$TEMP_DIR"); then
        log_error "Failed to download latest ACTS from GitHub"
        exit 1
    fi
    
    local DOWNLOADED_ACTS="$TEMP_DIR/.acts"
    
    if [[ "$latest" == "unknown" ]]; then
        log_error "Could not determine latest version from GitHub"
        exit 1
    fi
    
    if version_compare "$current" "$latest" && [[ "$force" != "true" ]]; then
        log_ok "Already up to date (v$current). Use --force to re-apply framework files."
        exit 0
    fi
    
    if [[ "$force" == "true" ]]; then
        log_bold "ACTS Force Update (re-apply v$current framework files from GitHub)"
    else
        log_bold "ACTS Update (v$current → v$latest)"
    fi
    echo ""
    
    # Step 1: Confirm (unless --yes for CI)
    if [[ "${ACTS_UPDATE_YES:-}" != "true" ]]; then
        log_info "This will:"
        echo "  1. Backup current framework files to .acts/backup/v$current/"
        echo "  2. Download and update .acts/operations/, .acts/schemas/, .acts/report-protocol.md from GitHub"
        echo "  3. Merge .acts/acts.json (preserve project config, add new fields)"
        echo "  4. Create a git commit"
        echo ""
        read -p "Proceed? (yes/no) " -r response
        if [[ "$response" != "yes" ]]; then
            log_info "Aborted."
            exit 0
        fi
    fi
    
    # Step 2: Create backup
    log_info "Creating backup..."
    mkdir -p "$BACKUP_DIR/v$current"
    
    # Backup framework files
    for item in operations schemas report-protocol.md code-review-interface.json; do
        local src="$ACTS_DIR/$item"
        if [[ -d "$src" ]]; then
            cp -r "$src" "$BACKUP_DIR/v$current/$item"
        elif [[ -f "$src" ]]; then
            cp "$src" "$BACKUP_DIR/v$current/$item"
        fi
    done
    
    # Backup acts.json
    cp "$ACTS_JSON" "$BACKUP_DIR/v$current/acts.json"
    
    # Write manifest
    cat > "$BACKUP_DIR/v$current/manifest.json" << EOF
{
  "timestamp": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "from_version": "$current",
  "to_version": "$latest",
  "files_backed_up": $(find "$BACKUP_DIR/v$current" -type f | wc -l),
  "forced": $force
}
EOF
    log_ok "Backup created: .acts/backup/v$current/"
    
    # Step 3: Download and update framework files from GitHub
    log_info "Downloading and updating framework files from GitHub..."
    
    # Update framework files from downloaded copy
    for item in operations schemas report-protocol.md code-review-interface.json; do
        local src="$DOWNLOADED_ACTS/$item"
        local dst="$ACTS_DIR/$item"
        if [[ -d "$src" ]]; then
            rm -rf "$dst"
            cp -r "$src" "$dst"
            local count=$(find "$dst" -type f | wc -l)
            log_ok "Updated .acts/$item/ ($count files)"
        elif [[ -f "$src" ]]; then
            cp "$src" "$dst"
            log_ok "Updated .acts/$item"
        fi
    done
    
    # Step 4: Update acts.json version
    log_info "Updating .acts/acts.json..."
    python3 -c "
import json
with open('$ACTS_JSON') as f:
    current = json.load(f)
current['manifest_version'] = '$latest'
with open('$ACTS_JSON', 'w') as f:
    json.dump(current, f, indent=2)
    f.write('\n')
"
    log_ok "Updated manifest_version to $latest"
    
    # Step 5: Validate
    log_info "Validating..."
    if python3 -m json.tool "$ACTS_JSON" > /dev/null 2>&1; then
        log_ok "acts.json is valid JSON"
    else
        log_error "acts.json validation failed!"
        exit 1
    fi
    
    # Step 6: Commit
    log_info "Creating git commit..."
    cd "$PROJECT_ROOT"
    git add -A .acts/
    if git diff --cached --quiet; then
        log_info "No changes to commit"
    else
        if [[ "$force" == "true" ]]; then
            git commit -m "chore: force re-apply ACTS framework v$current"
        else
            git commit -m "chore: update ACTS framework v$current → v$latest"
        fi
        log_ok "Committed"
    fi
    
    echo ""
    log_ok "Update complete!"
    echo "  Backup: .acts/backup/v$current/"
    echo "  Restore: .acts/bin/acts-update --restore v$current"
}

cmd_restore() {
    local version="$1"
    local backup_path="$BACKUP_DIR/$version"
    
    if [[ ! -d "$backup_path" ]]; then
        log_error "No backup found for $version"
        echo "  Available backups:"
        ls -1 "$BACKUP_DIR" 2>/dev/null || echo "  (none)"
        exit 1
    fi
    
    log_bold "ACTS Restore (v$version)"
    echo ""
    
    # Read manifest
    if [[ -f "$backup_path/manifest.json" ]]; then
        log_info "Backup info:"
        python3 -c "
import json
with open('$backup_path/manifest.json') as f:
    m = json.load(f)
print(f\"  Created: {m['timestamp']}\")
print(f\"  From: v{m['from_version']}\")
print(f\"  To: v{m['to_version']}\")
"
    fi
    
    echo ""
    read -p "Restore ACTS v$version? (yes/no) " -r response
    if [[ "$response" != "yes" ]]; then
        log_info "Aborted."
        exit 0
    fi
    
    # Restore framework files
    for item in operations schemas report-protocol.md code-review-interface.json; do
        local src="$backup_path/$item"
        local dst="$ACTS_DIR/$item"
        if [[ -d "$src" ]]; then
            rm -rf "$dst"
            cp -r "$src" "$dst"
            log_ok "Restored .acts/$item/"
        elif [[ -f "$src" ]]; then
            cp "$src" "$dst"
            log_ok "Restored .acts/$item"
        fi
    done
    
    # Restore acts.json version only (preserve project config)
    python3 -c "
import json
with open('$backup_path/acts.json') as f:
    backup = json.load(f)
with open('$ACTS_JSON') as f:
    current = json.load(f)
current['manifest_version'] = backup['manifest_version']
with open('$ACTS_JSON', 'w') as f:
    json.dump(current, f, indent=2)
    f.write('\n')
"
    log_ok "Restored manifest_version to $version"
    
    # Commit
    cd "$PROJECT_ROOT"
    git add -A .acts/
    git commit -m "chore: restore ACTS framework v$version"
    log_ok "Restored and committed"
}

# ─── Main ───────────────────────────────────────────────────────────────

usage() {
    cat << 'EOF'
ACTS Update Tool

Usage:
  acts-update --check           Check for available updates from GitHub
  acts-update --dry-run         Show what would change
  acts-update                   Apply update from GitHub (backup + download + apply)
  acts-update --force           Force update (re-apply framework files even if version matches)
  acts-update --restore v0.6.0  Restore from backup
  acts-update --yes             Auto-confirm (for CI/scripts)

Environment:
  ACTS_UPDATE_YES=true          Skip confirmation prompt

EOF
}

main() {
    local action="update" force="false"
    local restore_version=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check|-c)
                action="check"
                shift
                ;;
            --dry-run|-n)
                action="dry-run"
                shift
                ;;
            --force|-f)
                force="true"
                shift
                ;;
            --restore|-r)
                action="restore"
                shift
                if [[ $# -eq 0 ]]; then
                    log_error "Missing version for --restore"
                    exit 1
                fi
                restore_version="$1"
                shift
                ;;
            --yes|-y)
                export ACTS_UPDATE_YES="true"
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    case "$action" in
        check)
            cmd_check
            ;;
        dry-run)
            cmd_dry_run
            ;;
        update)
            cmd_update "$force"
            ;;
        restore)
            cmd_restore "$restore_version"
            ;;
    esac
}

main "$@"
