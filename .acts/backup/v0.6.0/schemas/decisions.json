{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://acts-standard.org/schemas/decisions/v0.5.0",
  "title": "ACTS Story Decisions",
  "description": "Schema for .story/decisions.json — structured record of decisions, rejected approaches, and open questions during story work.",
  "type": "object",
  "required": [
    "decisions",
    "rejected_approaches",
    "open_questions"
  ],
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision" },
      "description": "Decisions made during implementation that override or clarify plan entries."
    },
    "rejected_approaches": {
      "type": "array",
      "items": { "$ref": "#/$defs/rejected_approach" },
      "description": "Approaches tried and found not to work, preserved for cross-task learning."
    },
    "open_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/open_question" },
      "description": "Unresolved items that need developer input."
    }
  },
  "$defs": {
    "decision": {
      "type": "object",
      "required": [
        "task_id",
        "timestamp",
        "session",
        "topic",
        "decided",
        "reason",
        "evidence",
        "authority"
      ],
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Task this decision belongs to.",
          "pattern": "^T\\d+$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the decision."
        },
        "session": {
          "type": "string",
          "description": "Session filename (without .md) that made this decision.",
          "minLength": 1
        },
        "topic": {
          "type": "string",
          "description": "Short identifier for the decision topic (e.g., 'form_library', 'auth_method').",
          "minLength": 1
        },
        "plan_said": {
          "type": "string",
          "description": "What the plan entry originally specified. Omitted if plan was silent on this topic."
        },
        "decided": {
          "type": "string",
          "description": "What was actually decided.",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "description": "Why this decision was made.",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "description": "Verifiable evidence: file:line reference, direct code quote, or test output.",
          "minLength": 1
        },
        "authority": {
          "type": "string",
          "enum": ["developer_approved", "agent_decided"],
          "description": "Whether a human approved this decision or the agent decided autonomously."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Semantic tags for cross-task learning (e.g., ['frontend', 'forms'])."
        }
      }
    },
    "rejected_approach": {
      "type": "object",
      "required": [
        "task_id",
        "timestamp",
        "session",
        "approach",
        "reason",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Task where this approach was tried.",
          "pattern": "^T\\d+$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the approach was rejected."
        },
        "session": {
          "type": "string",
          "description": "Session filename (without .md) that rejected this approach.",
          "minLength": 1
        },
        "approach": {
          "type": "string",
          "description": "Description of the approach that was tried.",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "description": "Why this approach was rejected.",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "description": "Verifiable evidence: error output, test failure, or specific result.",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Semantic tags for cross-task relevance matching."
        }
      }
    },
    "open_question": {
      "type": "object",
      "required": [
        "task_id",
        "question",
        "raised_by",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Task where this question was raised.",
          "pattern": "^T\\d+$"
        },
        "question": {
          "type": "string",
          "description": "The unresolved question.",
          "minLength": 1
        },
        "raised_by": {
          "type": "string",
          "description": "Session filename (without .md) that raised this question.",
          "minLength": 1
        },
        "raised_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the question was raised."
        },
        "status": {
          "type": "string",
          "enum": ["unresolved", "resolved", "deferred"],
          "description": "Current status of the question."
        },
        "resolution": {
          "type": "string",
          "description": "How the question was resolved (required if status is resolved)."
        },
        "resolved_by": {
          "type": "string",
          "description": "Session or developer that resolved this question."
        }
      }
    }
  }
}
