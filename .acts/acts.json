{
  "manifest_version": "0.6.1",
  "conformance_level": "strict",
  "agent_framework": {
    "enabled": true,
    "name": "superpowers",
    "min_version": "5.0.0"
  },
  "gh_stack": {
    "enabled": false,
    "description": "GitHub Stacked PRs adapter (private preview). Turns task branches into stacked PRs.",
    "prefix": "story/<STORY_ID>",
    "numbered": true,
    "draft_prs": true
  },
  "description": "Project-level ACTS configuration \u2014 controls behavior, integration, and protocol settings.",
  "commit_convention": "conventional",
  "review_provider": "githuman",
  "review_provider_config": {
    "mode": "tui"
  },
  "allow_reopen_completed": false,
  "agent_roles": [
    "coder",
    "reviewer"
  ],
  "jira_integration": {
    "enabled": true,
    "description": "Jira integration for story-init auto-fetch and tracker-sync status push.",
    "fetch_fields": [
      "description",
      "summary",
      "issuetype",
      "labels",
      "components"
    ],
    "key_pattern": "^[A-Z]+-\\d+$",
    "sync": {
      "create_subtasks": true,
      "sync_on_completion": true,
      "status_map": {
        "TODO": null,
        "IN_PROGRESS": "In Progress",
        "DONE": "Done",
        "BLOCKED": null
      }
    }
  },
  "mcp_context_engine": {
    "enabled": false,
    "description": "Layer 7: MCP Context Engine. Optional. Provides operation-aware context delivery, compaction, anchoring, and verification via MCP server.",
    "server_path": ".acts/mcp-server",
    "transport": "stdio",
    "config": {
      "context_budget_default": 50000,
      "loop_threshold": 3,
      "turn_refresh_interval": 15,
      "compaction_auto_trigger": 10,
      "attention_optimization": true
    }
  }
}
