#!/bin/bash
# task-start operation

source .acts/lib/helpers.sh

# Read input
INPUT=$(acts_read_input)
TASK_ID=$(acts_get_input "$INPUT" "inputs.task_id")
ACTION=$(acts_get_input "$INPUT" "inputs.action")

acts_log "INFO" "Task start: $TASK_ID, action: $ACTION"

# Step 1-10: Implementation work happens elsewhere
# This operation is called after implementation is complete

if [ "$ACTION" == "complete" ]; then
    acts_log "INFO" "Task completion requested, running review gate"
    
    # Step 11: TASK-REVIEW GATE
    acts_log "INFO" "Calling task-review operation"
    
    REVIEW_OUTPUT=$(acts_call task-review --input task_id="$TASK_ID")
    REVIEW_STATUS=$(echo "$REVIEW_OUTPUT" | jq -r '.status')
    
    acts_log "INFO" "Review status: $REVIEW_STATUS"
    
    if [ "$REVIEW_STATUS" == "approved" ]; then
        acts_log "INFO" "Review approved, completing task"
        
        # Output success JSON
        jq -n \
            --arg task_id "$TASK_ID" \
            --argjson review_output "$REVIEW_OUTPUT" \
            '{status: "success", results: {task_id: $task_id, status: "DONE", review_status: "approved"}, artifacts: {review_output: $review_output}}'
        exit 0
    elif [ "$REVIEW_STATUS" == "changes_requested" ]; then
        acts_log "WARN" "Changes requested, task remains IN_PROGRESS"
        jq -n \
            --arg task_id "$TASK_ID" \
            --argjson review_output "$REVIEW_OUTPUT" \
            '{status: "changes_requested", results: {task_id: $task_id, reason: "Review changes requested"}, artifacts: {review_output: $review_output}}'
        exit 2
    else
        acts_log "ERROR" "Review failed with status: $REVIEW_STATUS"
        acts_error "Review operation failed"
        exit 1
    fi
else
    # Normal task start (implementation mode)
    acts_log "INFO" "Starting task implementation for $TASK_ID"
    
    echo "" >&2
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
    echo "🚀 TASK STARTED: $TASK_ID" >&2
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
    echo "" >&2
    echo "⚠️  IMPORTANT: When you complete this task, you MUST run:" >&2
    echo "" >&2
    echo "    acts run task-start --input task_id=$TASK_ID --input action=complete" >&2
    echo "" >&2
    echo "This will trigger the mandatory code review gate (task-review)." >&2
    echo "The agent CANNOT mark the task as DONE without your approval." >&2
    echo "" >&2
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
    echo "" >&2
    
    # **In strict mode (conformance_level: "strict"):**
    # After completing a logical batch of commits (1-5 commits):
    # a. Invoke commit-approve operation via acts_call
    # b. Parse approval result from JSON output
    # c. If changes_requested: address feedback, then loop back
    # d. If approved: continue implementation
    
    # Note: The actual commit-approve calls happen during implementation
    # after each batch of commits. Example usage:
    #
    # APPROVAL_OUTPUT=$(acts_call commit-approve \
    #     --input batch_number="$BATCH_NUM" \
    #     --input commit_count="$COMMIT_COUNT" \
    #     --input files_changed='["file1.js","file2.js"]' \
    #     --input commit_messages='["feat: add feature","fix: bug"]')
    #
    # APPROVAL_STATUS=$(echo "$APPROVAL_OUTPUT" | jq -r '.status')
    #
    # if [ "$APPROVAL_STATUS" != "approved" ]; then
    #     acts_log "WARN" "Changes requested for batch $BATCH_NUM"
    #     # Address feedback and loop back
    # fi
    
    jq -n \
        --arg task_id "$TASK_ID" \
        '{status: "success", results: {task_id: $task_id, status: "IN_PROGRESS"}, artifacts: {}}'
    exit 0
fi
