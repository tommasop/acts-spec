#!/bin/bash
# story-approve operation
# Final approval before story review

source .acts/lib/helpers.sh

# Read input
INPUT=$(acts_read_input)
STORY_ID=$(acts_get_input "$INPUT" "inputs.story_id")
TITLE=$(acts_get_input "$INPUT" "inputs.title")
AC_MET=$(acts_get_input "$INPUT" "inputs.acceptance_criteria_met")
AC_TOTAL=$(acts_get_input "$INPUT" "inputs.acceptance_criteria_total")
TESTS_PASS=$(acts_get_input "$INPUT" "inputs.tests_passing")
TESTS_TOTAL=$(acts_get_input "$INPUT" "inputs.tests_total")
ALL_REVIEWED=$(acts_get_input "$INPUT" "inputs.all_tasks_reviewed")
COMPLIANCE=$(acts_get_input "$INPUT" "inputs.compliance_issues")

acts_log "INFO" "Reviewing story $STORY_ID for approval"

# Step 1: Display story report
cat >&2 <<EOF

========================================
STORY APPROVAL REVIEW
========================================

Story: $STORY_ID — $TITLE

Acceptance Criteria: $AC_MET / $AC_TOTAL met
Tests: $TESTS_PASS / $TESTS_TOTAL passing
All Tasks Reviewed: $ALL_REVIEWED
EOF

if [ -n "$COMPLIANCE" ] && [ "$COMPLIANCE" != "[]" ]; then
    echo "" >&2
    echo "Compliance Issues:" >&2
    echo "$COMPLIANCE" | jq -r '.[] | "  - " + .' >&2
fi

cat >&2 <<EOF

========================================
EOF

# Step 2: Check if we can proceed
if [ "$AC_MET" -lt "$AC_TOTAL" ] || [ "$ALL_REVIEWED" != "true" ]; then
    acts_log "WARN" "Criteria not met, cannot approve"
    jq -n \
        --arg story_id "$STORY_ID" \
        '{
            status: "changes_requested",
            approved: false,
            story_status: "IN_PROGRESS",
            error: "Acceptance criteria not fully met or tasks not reviewed",
            results: {story_id: $story_id}
        }'
    exit 2
fi

# Step 3: GATE - Ask for approval
acts_log "INFO" "Waiting for final approval..."

# For demonstration, auto-approve

# Output approval result
jq -n \
    --arg story_id "$STORY_ID" \
    --arg title "$TITLE" \
    '{
        status: "approved",
        approved: true,
        story_status: "REVIEW",
        results: {
            story_id: $story_id,
            title: $title,
            status: "REVIEW"
        }
    }'

acts_log "INFO" "Story $STORY_ID approved for REVIEW"
exit 0
