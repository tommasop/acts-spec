# Function to run githuman review
run_githuman_review() {
    acts_log "INFO" "Launching GitHuman for code review..."
    
    local githuman_port=3847
    local server_pid=""
    local review_export_file=".story/reviews/active/${TASK_ID}-githuman-export.md"
    
    # Create review directory
    mkdir -p .story/reviews/active
    
    # Start githuman server
    acts_log "INFO" "Starting GitHuman server on port $githuman_port..."
    
    githuman serve --port "$githuman_port" --no-open &
    server_pid=$!
    
    # Wait for server to be ready
    local attempts=0
    local max_attempts=30
    while (( attempts < max_attempts )); do
        if curl -s "http://localhost:$githuman_port/health" > /dev/null 2>&1; then
            acts_log "INFO" "GitHuman server ready"
            break
        fi
        sleep 1
        ((attempts++))
    done
    
    if (( attempts >= max_attempts )); then
        acts_log "ERROR" "GitHuman server failed to start"
        [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null
        return 1
    fi
    
    # STEP 2: Show developer how to reach GitHuman and present menu
    echo "" >&2
    echo "═══════════════════════════════════════════════════════════════════" >&2
    echo "🌐 GITHUMAN CODE REVIEW READY" >&2
    echo "═══════════════════════════════════════════════════════════════════" >&2
    echo "" >&2
    echo "GitHuman is now running and ready for your review:" >&2
    echo "" >&2
    echo "  📍 URL: http://127.0.0.1:$githuman_port" >&2
    echo "  🔧 Server PID: $server_pid" >&2
    echo "" >&2
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
    echo "" >&2
    echo "📋 INSTRUCTIONS:" >&2
    echo "" >&2
    echo "  1. Open your browser to: http://127.0.0.1:$githuman_port" >&2
    echo "  2. Review the staged changes in GitHuman" >&2
    echo "  3. Close/submit your review in the GitHuman interface" >&2
    echo "  4. Return here and select an option from the menu below" >&2
    echo "" >&2
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
    echo "" >&2
    
    # STEP 5: Wait for developer to select menu option
    local review_completed=false
    local approval_status=""
    
    while [[ "$review_completed" == "false" ]]; do
        echo "" >&2
        echo "🔍 REVIEW MENU - Select an option:" >&2
        echo "" >&2
        echo "  [1] ✅ Approved - Changes look good, ready to merge" >&2
        echo "  [2] 📝 Changes Requested - Need modifications before approval" >&2
        echo "  [3] ❌ Cancel - Abort review, keep task in progress" >&2
        echo "" >&2
        
        local menu_choice
        if ! read_with_fallback "Enter your choice (1/2/3): " menu_choice; then
            echo "⚠️  Failed to read input, please try again" >&2
            continue
        fi
        
        # Normalize input
        menu_choice=$(echo "$menu_choice" | tr '[:upper:]' '[:lower:]' | xargs)
        
        case "$menu_choice" in
            1|approved|approve|yes|y)
                approval_status="approved"
                review_completed=true
                ;;
            2|changes|change|no|n)
                approval_status="changes_requested"
                review_completed=true
                ;;
            3|cancel|abort|stop|c)
                echo "" >&2
                echo "❌ Review cancelled by user. Task remains IN_PROGRESS." >&2
                [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null
                acts_log "INFO" "Review cancelled by user"
                jq -n \
                    '{status: "cancelled", results: {review_status: "cancelled", reason: "Review cancelled by user"}, artifacts: {}}'
                return 1
                ;;
            *)
                echo "" >&2
                echo "⚠️  Invalid choice. Please enter 1, 2, or 3" >&2
                ;;
        esac
    done
    
    # STEP 6: Export the GitHuman review to MD file
    echo "" >&2
    echo "📤 Exporting GitHuman review..." >&2
    
    if githuman export last --output "$review_export_file" 2>/dev/null; then
        acts_log "INFO" "GitHuman review exported to $review_export_file"
        echo "  ✓ Review exported to: $review_export_file" >&2
    else
        acts_log "WARN" "Could not export GitHuman review automatically"
        echo "  ⚠️  Could not auto-export review (this is OK, continuing...)" >&2
    fi
    
    # STEP 7: Kill the GitHuman instance
    echo "" >&2
    echo "🛑 Stopping GitHuman server (PID: $server_pid)..." >&2
    [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null
    sleep 1
    
    # Verify server stopped
    if curl -s "http://localhost:$githuman_port/health" > /dev/null 2>&1; then
        acts_log "WARN" "GitHuman server still running, force killing..."
        [[ -n "$server_pid" ]] && kill -9 "$server_pid" 2>/dev/null
    fi
    echo "  ✓ GitHuman server stopped" >&2
    
    # STEP 8: Read review file and act accordingly
    if [[ "$approval_status" == "approved" ]]; then
        echo "" >&2
        echo "✅ Review APPROVED - Proceeding with task completion..." >&2
        
        REVIEW_FILE=$(create_review_artifact "approved" "human via GitHuman" "Reviewed via GitHuman web interface" "githuman")
        ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
        
        acts_log "INFO" "Review approved, artifact archived: $ARCHIVED_FILE"
        
        jq -n \
            --arg review_file "$ARCHIVED_FILE" \
            --arg githuman_export "$review_export_file" \
            '{status: "approved", results: {review_status: "approved", reviewer: "human via GitHuman"}, artifacts: {review_file: $review_file, githuman_export: $githuman_export}}'
        return 0
        
    elif [[ "$approval_status" == "changes_requested" ]]; then
        echo "" >&2
        echo "📝 Changes requested. Please provide details:" >&2
        
        local comments
        if ! read_with_fallback "Describe what changes are needed: " comments; then
            comments="Changes requested via GitHuman review"
        fi
        
        REVIEW_FILE=$(create_review_artifact "changes_requested" "human via GitHuman" "$comments" "githuman")
        ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
        
        echo "" >&2
        echo "📝 Changes requested recorded. Task remains IN_PROGRESS." >&2
        echo "   Please address the feedback and run task-review again when ready." >&2
        echo "" >&2
        echo "   Next steps:" >&2
        echo "   1. Make the requested changes" >&2
        echo "   2. Stage the changes: git add ." >&2
        echo "   3. Run review again: acts run task-review --input task_id=$TASK_ID" >&2
        
        acts_log "INFO" "Changes requested, artifact archived: $ARCHIVED_FILE"
        
        # STEP 9: Return status that will trigger a loop back
        jq -n \
            --arg review_file "$ARCHIVED_FILE" \
            --arg comments "$comments" \
            --arg githuman_export "$review_export_file" \
            '{status: "changes_requested", results: {review_status: "changes_requested", reason: "Review changes requested", comments: $comments}, artifacts: {review_file: $review_file, githuman_export: $githuman_export}}'
        return 2
    fi
}

