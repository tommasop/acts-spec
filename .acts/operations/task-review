# Function to run githuman review
run_githuman_review() {
    acts_log "INFO" "Launching GitHuman for code review..."
    
    local githuman_port=3847
    local githuman_timeout=300
    local review_export_file=".story/reviews/active/${TASK_ID}-githuman.json"
    
    # Create review directory
    mkdir -p .story/reviews/active
    
    # Check if githuman server is already running
    local server_pid=""
    if curl -s "http://localhost:$githuman_port/health" > /dev/null 2>&1; then
        acts_log "INFO" "GitHuman server already running on port $githuman_port"
    else
        acts_log "INFO" "Starting GitHuman server on port $githuman_port..."
        
        # Start githuman server in background
        githuman serve --port "$githuman_port" --no-open &
        server_pid=$!
        
        # Wait for server to be ready
        local attempts=0
        local max_attempts=30
        while (( attempts < max_attempts )); do
            if curl -s "http://localhost:$githuman_port/health" > /dev/null 2>&1; then
                acts_log "INFO" "GitHuman server ready"
                break
            fi
            sleep 1
            ((attempts++))
        done
        
        if (( attempts >= max_attempts )); then
            acts_log "ERROR" "GitHuman server failed to start"
            [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null
            return 1
        fi
    fi
    
    # Create pre-review artifact
    create_review_artifact "in_progress" "GitHuman" "Review in progress via GitHuman" "githuman"
    
    if is_interactive_terminal; then
        # Interactive mode - tell user to open browser
        echo "" >&2
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
        echo "🌐 GitHuman Review Started" >&2
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
        echo "" >&2
        echo "GitHuman server is running at: http://localhost:$githuman_port" >&2
        echo "" >&2
        echo "Please open your browser and review the staged changes." >&2
        echo "" >&2
        
        # Wait for user to complete review
        while true; do
            read -p "Have you completed the review in GitHuman? (yes/no/cancel) " -r response >&2
            case "$response" in
                yes|y|Y|approved)
                    break
                    ;;
                cancel|skip)
                    acts_log "INFO" "Review cancelled by user"
                    [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null
                    jq -n \
                        '{status: "cancelled", results: {review_status: "cancelled"}, artifacts: {}}'
                    return 1
                    ;;
                *)
                    echo "Please enter 'yes' when review is complete or 'cancel' to abort" >&2
                    ;;
            esac
        done
        
        # Try to export review from githuman
        if githuman export last --output "$review_export_file" 2>/dev/null; then
            acts_log "INFO" "GitHuman review exported to $review_export_file"
        else
            acts_log "WARN" "Could not export GitHuman review automatically"
        fi
        
        # Ask for approval status
        while true; do
            read -p "Was the review approved? (yes/no) " -r response >&2
            case "$response" in
                yes|y|Y|approved)
                    REVIEW_FILE=$(create_review_artifact "approved" "human via GitHuman" "Reviewed via GitHuman web interface" "githuman")
                    ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                    
                    [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null
                    
                    acts_log "INFO" "Review approved, artifact archived: $ARCHIVED_FILE"
                    
                    jq -n \
                        --arg review_file "$ARCHIVED_FILE" \
                        '{status: "approved", results: {review_status: "approved", reviewer: "human via GitHuman"}, artifacts: {review_file: $review_file}}'
                    return 0
                    ;;
                no|n|N|changes)
                    read -p "Enter review comments: " -r comments >&2
                    REVIEW_FILE=$(create_review_artifact "changes_requested" "human via GitHuman" "$comments" "githuman")
                    ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                    
                    [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null
                    
                    acts_log "INFO" "Changes requested, artifact archived: $ARCHIVED_FILE"
                    
                    jq -n \
                        --arg review_file "$ARCHIVED_FILE" \
                        --arg comments "$comments" \
                        '{status: "changes_requested", results: {review_status: "changes_requested", reason: "Review changes requested", comments: $comments}, artifacts: {review_file: $review_file}}'
                    return 2
                    ;;
                *)
                    echo "Please enter 'yes' or 'no'" >&2
                    ;;
            esac
        done
        
    else
        # Non-interactive mode - generate review prompt
        acts_log "INFO" "Non-interactive environment detected"
        acts_log "INFO" "GitHuman server started at http://localhost:$githuman_port"
        
        REVIEW_PROMPT=".story/reviews/active/${TASK_ID}-review-prompt.md"
        
        cat > "$REVIEW_PROMPT" << EOF
┌─────────────────────────────────────────────────────────────────┐
│  GITHUMAN REVIEW REQUIRED                                       │
├─────────────────────────────────────────────────────────────────┤
│                                                                 │
│  GitHuman server is running at:                                 │
│  http://localhost:$githuman_port                                │
│                                                                 │
│  TO COMPLETE THE REVIEW:                                        │
│                                                                 │
│  1. Open your browser to the URL above                         │
│  2. Review the staged changes in GitHuman                      │
│  3. After reviewing, return here and respond with:              │
│                                                                 │
│     - "approved"  → if the changes look good                   │
│     - "changes"   → list specific changes needed               │
│                                                                 │
│  Server PID: $server_pid                                       │
│  To stop server: kill $server_pid                              │
│                                                                 │
└─────────────────────────────────────────────────────────────────┘

EOF
        
        # Append changes summary
        generate_summary_view >> "$REVIEW_PROMPT"
        
        acts_log "INFO" "Review prompt saved to: $REVIEW_PROMPT"
        
        jq -n \
            --arg prompt_file "$REVIEW_PROMPT" \
            --arg port "$githuman_port" \
            --arg pid "$server_pid" \
            '{status: "manual_review_required", results: {review_status: "pending", reason: "GitHuman review required - non-interactive environment", port: $port, pid: $pid}, artifacts: {prompt_file: $prompt_file}}'
        return 3
    fi
}

# Function to run lazygit review
run_lazygit_review() {
    acts_log "INFO" "Launching lazygit for code review..."
    
    if ! is_interactive_terminal; then
        acts_log "WARN" "lazygit requires interactive terminal"
        return 1
    fi
    
    # Create pre-review artifact
    create_review_artifact "in_progress" "lazygit" "Review in progress via lazygit" "lazygit"
    
    # Launch lazygit
    lazygit status
    local exit_code=$?
    
    acts_log "INFO" "lazygit exited with code $exit_code"
    
    # After lazygit exits, prompt for review result
    echo "" >&2
    echo "=== Lazygit Review Complete ===" >&2
    echo "" >&2
    
    while true; do
        read -p "Was the review approved? (yes/no) " -r response >&2
        case "$response" in
            yes|y|Y|approved)
                REVIEW_FILE=$(create_review_artifact "approved" "human via lazygit" "Reviewed via lazygit TUI" "lazygit")
                ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                
                acts_log "INFO" "Review approved, artifact archived: $ARCHIVED_FILE"
                
                jq -n \
                    --arg review_file "$ARCHIVED_FILE" \
                    '{status: "approved", results: {review_status: "approved", reviewer: "human via lazygit"}, artifacts: {review_file: $review_file}}'
                return 0
                ;;
            no|n|N|changes)
                read -p "Enter review comments: " -r comments >&2
                REVIEW_FILE=$(create_review_artifact "changes_requested" "human via lazygit" "$comments" "lazygit")
                ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                
                acts_log "INFO" "Changes requested, artifact archived: $ARCHIVED_FILE"
                
                jq -n \
                    --arg review_file "$ARCHIVED_FILE" \
                    --arg comments "$comments" \
                    '{status: "changes_requested", results: {review_status: "changes_requested", reason: "Review changes requested", comments: $comments}, artifacts: {review_file: $review_file}}'
                return 2
                ;;
            *)
                echo "Please enter 'yes' or 'no'" >&2
                ;;
        esac
    done
}

# Function to run manual review fallback
run_manual_review() {
    acts_log "INFO" "Using manual review fallback (mode: $REVIEW_MODE)"
    
    # Generate the appropriate view
    if [[ "$REVIEW_MODE" == "full" ]]; then
        generate_full_view >&2
    else
        generate_summary_view >&2
    fi
    
    if is_interactive_terminal; then
        # Interactive - ask for approval
        while true; do
            read -p "Was the review approved? (yes/no) " -r response >&2
            case "$response" in
                yes|y|Y|approved)
                    REVIEW_FILE=$(create_review_artifact "approved" "human (manual review)" "Reviewed via manual diff inspection" "manual")
                    ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                    
                    acts_log "INFO" "Review approved, artifact archived: $ARCHIVED_FILE"
                    
                    jq -n \
                        --arg review_file "$ARCHIVED_FILE" \
                        '{status: "approved", results: {review_status: "approved", reviewer: "human"}, artifacts: {review_file: $review_file}}'
                    return 0
                    ;;
                no|n|N|changes)
                    read -p "Enter review comments: " -r comments >&2
                    REVIEW_FILE=$(create_review_artifact "changes_requested" "human (manual review)" "$comments" "manual")
                    ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                    
                    acts_log "INFO" "Changes requested, artifact archived: $ARCHIVED_FILE"
                    
                    jq -n \
                        --arg review_file "$ARCHIVED_FILE" \
                        --arg comments "$comments" \
                        '{status: "changes_requested", results: {review_status: "changes_requested", reason: "Review changes requested", comments: $comments}, artifacts: {review_file: $review_file}}'
                    return 2
                    ;;
                *)
                    echo "Please enter 'yes' or 'no'" >&2
                    ;;
            esac
        done
    else
        # Non-interactive
        REVIEW_PROMPT=".story/reviews/active/${TASK_ID}-review-prompt.md"
        mkdir -p .story/reviews/active
        
        if [[ "$REVIEW_MODE" == "full" ]]; then
            generate_full_view > "$REVIEW_PROMPT"
        else
            generate_summary_view > "$REVIEW_PROMPT"
        fi
        
        acts_log "INFO" "Review prompt created: $REVIEW_PROMPT"
        
        jq -n \
            --arg prompt_file "$REVIEW_PROMPT" \
            --arg mode "$REVIEW_MODE" \
            '{status: "manual_review_required", results: {review_status: "pending", reason: "Manual review required - non-interactive environment", mode: $mode}, artifacts: {prompt_file: $prompt_file}}'
        return 3
    fi
}

# Main logic - select and run appropriate review tool
case "$REVIEW_PROVIDER" in
    githuman)
        if githuman_available; then
            run_githuman_review
        else
            acts_log "WARN" "GitHuman requested but not available, falling back to lazygit"
            if lazygit_available; then
                run_lazygit_review
            else
                acts_log "WARN" "lazygit also not available, using manual review"
                run_manual_review
            fi
        fi
        ;;
    lazygit)
        if lazygit_available; then
            run_lazygit_review
        else
            acts_log "WARN" "lazygit requested but not available, falling back to manual review"
            run_manual_review
        fi
        ;;
    manual)
        run_manual_review
        ;;
    auto|*)
        # Auto-detect: prefer githuman, then lazygit, then manual
        if githuman_available; then
            acts_log "INFO" "Auto-detected GitHuman, launching..."
            run_githuman_review
        elif lazygit_available; then
            acts_log "INFO" "Auto-detected lazygit, launching..."
            run_lazygit_review
        else
            acts_log "INFO" "No review tool available, using manual review"
            run_manual_review
        fi
        ;;
esac
