#!/bin/bash
# task-review operation
# Reads input from stdin, writes output to stdout
#
# This script handles code review using GitHuman as the primary tool,
# with fallback to lazygit and manual review when needed.
#
# Environment Variables:
#   ACTS_REVIEW_MODE=summary     - Show summary view for manual review (default)
#   ACTS_REVIEW_MODE=full        - Show file-by-file with full content for manual review
#   ACTS_REVIEW_PROVIDER=auto    - Auto-detect available tool (default)
#   ACTS_REVIEW_PROVIDER=githuman - Force GitHuman
#   ACTS_REVIEW_PROVIDER=lazygit - Force lazygit
#   ACTS_REVIEW_PROVIDER=manual  - Force manual review

source .acts/lib/helpers.sh

# Read input
INPUT=$(acts_read_input)
TASK_ID=$(acts_get_input "$INPUT" "inputs.task_id")
STORY_ID=$(acts_get_input "$INPUT" "inputs.story_id")
REVIEW_MODE="${ACTS_REVIEW_MODE:-summary}"

# Get provider from environment or config, default to auto-detect
REVIEW_PROVIDER="${ACTS_REVIEW_PROVIDER:-auto}"
if [[ "$REVIEW_PROVIDER" == "auto" ]]; then
    # Check config file
    if [[ -f ".acts/acts.json" ]]; then
        REVIEW_PROVIDER=$(python3 -c "
import json
with open('.acts/acts.json') as f:
    data = json.load(f)
print(data.get('review_provider', 'auto'))
" 2>/dev/null || echo "auto")
    fi
fi

echo ""
echo "══════════════════════════════════════════════════════════════════════════════════════════════════════════════════" >&2
echo "🔒 CODE REVIEW GATE REACHED FOR TASK: $TASK_ID" >&2
echo "══════════════════════════════════════════════════════════════════════════════════════════════════════════════════" >&2
echo "" >&2
echo "⚠️  THE AGENT HAS REACHED THE MANDATORY CODE REVIEW GATE" >&2
echo "" >&2
echo "    Review Provider: $REVIEW_PROVIDER" >&2
echo "    Review Mode: $REVIEW_MODE" >&2
echo "" >&2
echo "    The agent CANNOT proceed without your explicit approval." >&2
echo "    This is a HARD GATE - the task cannot be marked DONE without review." >&2
echo "" >&2
echo "══════════════════════════════════════════════════════════════════════════════════════════════════════════════════" >&2
echo "" >&2

acts_log "INFO" "Starting review for task $TASK_ID (provider: $REVIEW_PROVIDER, mode: $REVIEW_MODE)"

# Function to check if we're in an interactive terminal
is_interactive_terminal() {
    [[ -t 0 ]] && [[ -t 1 ]] && [[ -t 2 ]]
}

# Function to check if githuman is installed
githuman_available() {
    command -v githuman &> /dev/null
}

# Function to check if lazygit is installed
lazygit_available() {
    command -v lazygit &> /dev/null
}

# Function to get file change stats
get_change_stats() {
    local added=$(git diff --staged --numstat | awk '{sum+=$1} END {print sum+0}')
    local deleted=$(git diff --staged --numstat | awk '{sum+=$2} END {print sum+0}')
    local net=$((added - deleted))
    local files_changed=$(git diff --staged --name-only | wc -l)
    local new_files=$(git diff --staged --name-status | grep '^A' | wc -l)
    local modified_files=$(git diff --staged --name-status | grep '^M' | wc -l)
    local deleted_files=$(git diff --staged --name-status | grep '^D' | wc -l)
    
    echo "added=$added deleted=$deleted net=$net files=$files_changed new=$new_files modified=$modified_files deleted=$deleted_files"
}

# Function to categorize file by extension
get_file_icon() {
    local file="$1"
    local ext="${file##*.}"
    
    case "$ext" in
        sh|bash) echo "🔧" ;;
        py) echo "🐍" ;;
        js|ts|jsx|tsx) echo "📜" ;;
        md) echo "📝" ;;
        json|yaml|yml) echo "⚙️" ;;
        html|css) echo "🌐" ;;
        *) echo "📄" ;;
    esac
}

# Function to get file status
get_file_status() {
    local file="$1"
    git diff --staged --name-status | grep "$(basename "$file")$" | cut -f1
}

# Function to get line count
get_line_count() {
    local file="$1"
    git diff --staged --numstat "$file" 2>/dev/null | awk '{print $1 + $2}' || echo "0"
}

# Function to truncate diff
get_truncated_diff() {
    local file="$1"
    local max_lines="${2:-30}"
    local total_lines
    total_lines=$(git diff --staged "$file" 2>/dev/null | wc -l)
    
    if (( total_lines <= max_lines )); then
        git diff --staged "$file" 2>/dev/null
    else
        git diff --staged "$file" 2>/dev/null | head -n "$max_lines"
        echo ""
        echo "... ($((total_lines - max_lines)) more lines) ..."
        echo "Use 'git diff --staged $file' to see full diff"
    fi
}

# Function to get full diff
get_full_diff() {
    local file="$1"
    git diff --staged "$file" 2>/dev/null
}

# Function to create review artifact
create_review_artifact() {
    local status="$1"
    local reviewer="$2"
    local comments="${3:-}"
    local tool="${4:-manual}"
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    
    mkdir -p .story/reviews/active
    
    local review_file=".story/reviews/active/${TASK_ID}-review.md"
    
    cat > "$review_file" << EOF
# Review — $TASK_ID

- **Story:** ${STORY_ID:-unknown}
- **Reviewer:** $reviewer
- **Date:** $timestamp
- **Status:** $status
- **Tool:** $tool

## Files Reviewed

$(git diff --staged --name-only | sed 's/^/- /')

## Comments

${comments:-No comments provided}

## Stats

$(git diff --staged --stat)

## Change Summary

$(get_change_stats | tr ' ' '\n' | sed 's/^/- /')

EOF
    
    echo "$review_file"
}

# Function to archive review
archive_review() {
    local review_file="$1"
    mkdir -p .story/reviews/archive
    mv "$review_file" ".story/reviews/archive/${TASK_ID}-review.md"
    echo ".story/reviews/archive/${TASK_ID}-review.md"
}

