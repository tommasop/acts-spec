✅ $new files added     |  📝 $modified files modified  |  ❌ $deleted files deleted
📈 +$added lines        |  📉 -$deleted lines         |  🔄 Net: $net lines

EOF
    
    # File-by-file review
    local file_num=1
    local total_files=$((new + modified + deleted))
    
    git diff --staged --name-only | while read -r file; do
        local icon=$(get_file_icon "$file")
