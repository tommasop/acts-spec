┃  CODE REVIEW — Task ${TASK_ID}                                         ┃
┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛

📊 CHANGES SUMMARY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
✅ $new files added     |  📝 $modified files modified  |  ❌ $deleted files deleted
📈 +$added lines        |  📉 -$deleted lines         |  🔄 Net: $net lines

EOF
    
    # New files section
    if (( new > 0 )); then
        echo "🆕 NEW FILES ($new)"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        git diff --staged --name-status | grep '^A' | cut -f2 | while read -r file; do
            local icon=$(get_file_icon "$file")
            local lines=$(get_line_count "$file")
            echo "  $icon $file (+$lines lines)"
            
            # Show first line of diff as description
            local desc
            desc=$(git diff --staged "$file" 2>/dev/null | grep '^+' | grep -v '^+++' | head -1 | sed 's/^+//' | cut -c1-60)
            if [[ -n "$desc" && "$desc" != "#!/"* && "$desc" != "#"* ]]; then
                echo "     └─ ${desc}..."
            elif [[ -n "$desc" ]]; then
                echo "     └─ ${desc}"
            fi
        done
        echo ""
    fi
    
    # Modified files section
    if (( modified > 0 )); then
        echo "✏️ MODIFIED FILES ($modified)"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        git diff --staged --name-status | grep '^M' | cut -f2 | while read -r file; do
            local icon=$(get_file_icon "$file")
            local lines=$(get_line_count "$file")
            echo "  $icon $file ($lines lines changed)"
        done
        echo ""
    fi
    
    # Deleted files section
    if (( deleted > 0 )); then
        echo "🗑️  DELETED FILES ($deleted)"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        git diff --staged --name-status | grep '^D' | cut -f2 | while read -r file; do
            local icon=$(get_file_icon "$file")
            echo "  $icon $file"
        done
        echo ""
    fi
    
    # Review checkpoints
    cat << 'EOF'
💡 REVIEW CHECKPOINTS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  ☐ Security: Any hardcoded secrets or credentials?
  ☐ Tests: New functionality has test coverage?
  ☐ Documentation: Public APIs/methods documented?
  ☐ Error Handling: Edge cases handled gracefully?
  ☐ Style: Follows project conventions (see AGENTS.md)?
  ☐ Performance: Any obvious performance concerns?

EOF
    
    # Show truncated diffs for larger files
    echo "📋 KEY DIFFS (truncated)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    local count=0
    git diff --staged --name-only | while read -r file && (( count < 3 )); do
        echo "File: $file ($(get_line_count "$file") lines changed)"
        echo "─────────────────────────────────────────────────────────────────"
        get_truncated_diff "$file" 20
        echo ""
        echo ""
        ((count++))
    done
    
    cat << 'EOF'
✅ HOW TO RESPOND
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Option 1 - Quick Approval:
  approved
  [optional: brief comment]

Option 2 - Request Changes (Conventional Comments format):
  changes:
  - file.py:42: issue - Critical problem found
  - file.py:56: suggestion - Propose better approach
  - tests/test.py:12: nitpick - Minor style issue
  - file.py:89: praise - Great solution!

Labels: issue|suggestion|praise|nitpick|question|thought|todo|note
Decorations: (blocking)|(non-blocking)|(security)|(test)|(ux)

For full file-by-file review, set: ACTS_REVIEW_MODE=full

EOF
}

# Function to generate full file-by-file view
generate_full_view() {
    local stats
    stats=$(get_change_stats)
    eval "$stats"
    
    cat << EOF

┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
┃  CODE REVIEW — Task ${TASK_ID} (FULL VIEW)                             ┃
┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛

