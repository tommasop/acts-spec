# Function to check if we can read interactively
can_read_interactively() {
    # Check if /dev/tty exists and is readable
    if [[ -r /dev/tty ]]; then
        return 0
    fi
    # Check if stdin is a terminal
    if [[ -t 0 ]]; then
        return 0
    fi
    return 1
}

# Function to read with fallback
read_with_fallback() {
    local prompt="$1"
    local var_name="$2"
    
    if [[ -r /dev/tty ]]; then
        # Try /dev/tty first (for proper interactive input)
        read -rp "$prompt" "$var_name" < /dev/tty
    elif [[ -t 0 ]]; then
        # Fall back to stdin if it's a terminal
        read -rp "$prompt" "$var_name"
    else
        # No interactive input available - this shouldn't happen if we're blocking
        # But handle it gracefully by returning empty
        return 1
    fi
}

# Function to run manual review fallback
run_manual_review() {
    acts_log "INFO" "Using manual review fallback (mode: $REVIEW_MODE)"
    
    # Generate the appropriate view
    if [[ "$REVIEW_MODE" == "full" ]]; then
        generate_full_view >&2
    else
        generate_summary_view >&2
    fi
    
    # ALWAYS wait for approval - this is a HARD GATE
    # Even in non-interactive mode, we block and wait for user input
    echo "" >&2
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
    echo "🔒 REVIEW GATE ACTIVE - WAITING FOR APPROVAL" >&2
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >&2
    echo "" >&2
    echo "⚠️  AGENT MUST STOP HERE AND WAIT FOR EXPLICIT APPROVAL" >&2
    echo "" >&2
    echo "This is a HARD GATE. The agent cannot proceed without your review." >&2
    echo "" >&2
    
    # Check if we can read interactively
    if ! can_read_interactively; then
        echo "⚠️  WARNING: No interactive terminal available (/dev/tty not found)" >&2
        echo "" >&2
        echo "Creating approval file mechanism..." >&2
        echo "" >&2
        
        # Create an approval file that the user can write to
        local approval_file=".story/reviews/active/${TASK_ID}-approval.txt"
        
        cat > "$approval_file" << EOF
REVIEW GATE FOR TASK: $TASK_ID

To approve this review, write one of the following to this file:
  - "approved"  → if changes look good
  - "changes: <your comments>" → to request modifications  
  - "cancel"    → to abort the review

Then save the file. The agent will detect your response.

Current status: WAITING FOR APPROVAL
EOF

        echo "Created approval file: $approval_file" >&2
        echo "" >&2
        echo "Please edit this file with your decision." >&2
        echo "The agent will wait until you provide input..." >&2
        echo "" >&2
        
        # Wait for the approval file to be modified
        local last_modified=$(stat -c %Y "$approval_file" 2>/dev/null || stat -f %m "$approval_file" 2>/dev/null)
        local attempts=0
        local max_attempts=3600  # Wait up to 1 hour (checking every second)
        
        while (( attempts < max_attempts )); do
            sleep 1
            local current_modified=$(stat -c %Y "$approval_file" 2>/dev/null || stat -f %m "$approval_file" 2>/dev/null)
            
            if [[ "$current_modified" != "$last_modified" ]]; then
                # File was modified, read the response
                local response
                response=$(cat "$approval_file" | grep -v "^REVIEW GATE\|^$\|^To approve\|^  -\|^Then\|^Current\|Please\|The agent" | head -1 | xargs)
                
                # Convert to lowercase for comparison
                local response_lower
                response_lower=$(echo "$response" | tr '[:upper:]' '[:lower:]')
                
                case "$response_lower" in
                    approved|approve|yes|y)
                        echo "" >&2
                        echo "✅ Review APPROVED - Proceeding with task completion..." >&2
                        REVIEW_FILE=$(create_review_artifact "approved" "human (manual review)" "Reviewed via file-based approval" "manual")
                        ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                        rm -f "$approval_file"
                        
                        acts_log "INFO" "Review approved, artifact archived: $ARCHIVED_FILE"
                        
                        jq -n \
                            --arg review_file "$ARCHIVED_FILE" \
                            '{status: "approved", results: {review_status: "approved", reviewer: "human"}, artifacts: {review_file: $review_file}}'
                        return 0
                        ;;
                    changes|change*)
                        local comments="${response#changes:}"
                        comments=$(echo "$comments" | xargs)
                        
                        echo "" >&2
                        echo "📝 Changes requested. Task remains IN_PROGRESS." >&2
                        
                        REVIEW_FILE=$(create_review_artifact "changes_requested" "human (manual review)" "$comments" "manual")
                        ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                        rm -f "$approval_file"
                        
                        acts_log "INFO" "Changes requested, artifact archived: $ARCHIVED_FILE"
                        
                        jq -n \
                            --arg review_file "$ARCHIVED_FILE" \
                            --arg comments "$comments" \
                            '{status: "changes_requested", results: {review_status: "changes_requested", reason: "Review changes requested", comments: $comments}, artifacts: {review_file: $review_file}}'
                        return 2
                        ;;
                    cancel|abort|stop)
                        echo "" >&2
                        echo "❌ Review cancelled by user. Task remains IN_PROGRESS." >&2
                        rm -f "$approval_file"
                        acts_log "INFO" "Review cancelled by user"
                        jq -n \
                            '{status: "cancelled", results: {review_status: "cancelled", reason: "Review cancelled by user"}, artifacts: {}}'
                        return 1
                        ;;
                esac
            fi
            
            ((attempts++))
            
            # Show a waiting indicator every 10 seconds
            if (( attempts % 10 == 0 )); then
                echo -n "." >&2
            fi
        done
        
        # Timeout reached
        echo "" >&2
        echo "❌ Review timed out after 1 hour" >&2
        rm -f "$approval_file"
        jq -n \
            '{status: "error", error: "Review timed out waiting for approval"}'
        return 1
    fi
    
    # Interactive mode - read from terminal
    while true; do
        echo "" >&2
        local response
        if ! read_with_fallback "Enter your review decision (approved/changes/cancel): " response; then
            echo "⚠️  Failed to read input" >&2
            continue
        fi
        
        # Normalize response
        response=$(echo "$response" | tr '[:upper:]' '[:lower:]' | xargs)
        
        case "$response" in
            approved|approve|yes|y)
                echo "" >&2
                echo "✅ Review APPROVED - Proceeding with task completion..." >&2
                REVIEW_FILE=$(create_review_artifact "approved" "human (manual review)" "Reviewed via manual diff inspection" "manual")
                ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                
                acts_log "INFO" "Review approved, artifact archived: $ARCHIVED_FILE"
                
                jq -n \
                    --arg review_file "$ARCHIVED_FILE" \
                    '{status: "approved", results: {review_status: "approved", reviewer: "human"}, artifacts: {review_file: $review_file}}'
                return 0
                ;;
            changes|change|no|n|request)
                echo "" >&2
                echo "📝 Changes requested. Please provide your comments:" >&2
                local comments
                if ! read_with_fallback "Review comments (describe what needs to change): " comments; then
                    echo "⚠️  Failed to read comments" >&2
                    continue
                fi
                
                REVIEW_FILE=$(create_review_artifact "changes_requested" "human (manual review)" "$comments" "manual")
                ARCHIVED_FILE=$(archive_review "$REVIEW_FILE")
                
                echo "" >&2
                echo "📝 Changes requested recorded. Task remains IN_PROGRESS." >&2
                echo "   Address the feedback and run task-review again when ready." >&2
                
                acts_log "INFO" "Changes requested, artifact archived: $ARCHIVED_FILE"
                
                jq -n \
                    --arg review_file "$ARCHIVED_FILE" \
                    --arg comments "$comments" \
                    '{status: "changes_requested", results: {review_status: "changes_requested", reason: "Review changes requested", comments: $comments}, artifacts: {review_file: $review_file}}'
                return 2
                ;;
            cancel|abort|stop)
                echo "" >&2
                echo "❌ Review cancelled by user. Task remains IN_PROGRESS." >&2
                acts_log "INFO" "Review cancelled by user"
                jq -n \
                    '{status: "cancelled", results: {review_status: "cancelled", reason: "Review cancelled by user"}, artifacts: {}}'
                return 1
                ;;
            *)
                echo "" >&2
                echo "⚠️  Invalid response. Please enter one of:" >&2
                echo "   - 'approved'  → if changes look good" >&2
                echo "   - 'changes'   → to request modifications" >&2
                echo "   - 'cancel'    → to abort the review" >&2
                ;;
        esac
    done
}

# Main logic - select and run appropriate review tool
case "$REVIEW_PROVIDER" in
    githuman)
        if githuman_available; then
            run_githuman_review
        else
            acts_log "WARN" "GitHuman requested but not available, falling back to lazygit"
            if lazygit_available; then
                run_lazygit_review
            else
                acts_log "WARN" "lazygit also not available, using manual review"
                run_manual_review
            fi
        fi
        ;;
    lazygit)
        if lazygit_available; then
            run_lazygit_review
        else
            acts_log "WARN" "lazygit requested but not available, falling back to manual review"
            run_manual_review
        fi
        ;;
    manual)
        run_manual_review
        ;;
    auto|*)
        # Auto-detect: prefer githuman, then lazygit, then manual
        if githuman_available; then
            acts_log "INFO" "Auto-detected GitHuman, launching..."
            run_githuman_review
        elif lazygit_available; then
            acts_log "INFO" "Auto-detected lazygit, launching..."
            run_lazygit_review
        else
            acts_log "INFO" "No review tool available, using manual review"
            run_manual_review
        fi
        ;;
esac
