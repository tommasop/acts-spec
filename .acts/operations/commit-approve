#!/bin/bash
# commit-approve operation
# Reviews and approves a batch of commits

source .acts/lib/helpers.sh

# Read input
INPUT=$(acts_read_input)
BATCH_NUMBER=$(acts_get_input "$INPUT" "inputs.batch_number")
COMMIT_COUNT=$(acts_get_input "$INPUT" "inputs.commit_count")
FILES_CHANGED=$(acts_get_input "$INPUT" "inputs.files_changed")
COMMIT_MESSAGES=$(acts_get_input "$INPUT" "inputs.commit_messages")
TEST_RESULTS=$(acts_get_input "$INPUT" "inputs.test_results")
LINT_RESULTS=$(acts_get_input "$INPUT" "inputs.lint_results")

acts_log "INFO" "Reviewing commit batch #$BATCH_NUMBER ($COMMIT_COUNT commits)"

# Step 1: Display batch report
cat >&2 <<EOF

========================================
COMMIT BATCH REVIEW
========================================

Batch: #$BATCH_NUMBER
Commits: $COMMIT_COUNT

Files Changed:
EOF

echo "$FILES_CHANGED" | jq -r '.[] | "  - " + .' >&2

cat >&2 <<EOF

Commit Messages:
EOF

echo "$COMMIT_MESSAGES" | jq -r '.[] | "  - " + .' >&2

if [ -n "$TEST_RESULTS" ]; then
    echo "" >&2
    echo "Test Results:" >&2
    echo "$TEST_RESULTS" >&2
fi

if [ -n "$LINT_RESULTS" ]; then
    echo "" >&2
    echo "Lint Results:" >&2
    echo "$LINT_RESULTS" >&2
fi

cat >&2 <<EOF

========================================
EOF

# Step 2: GATE - Ask for approval
acts_log "INFO" "Waiting for approval..."

# For demonstration, auto-approve
# In production: prompt for approve/changes_requested

# Output approval result
jq -n \
    --argjson batch "$BATCH_NUMBER" \
    '{
        status: "approved",
        approved: true,
        action: "approved",
        feedback: null,
        results: {
            batch_number: $batch,
            approved: true
        }
    }'

acts_log "INFO" "Batch #$BATCH_NUMBER approved"
exit 0
