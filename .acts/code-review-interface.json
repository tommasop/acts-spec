{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://acts-standard.org/schemas/code-review-interface/v0.4.0",
  "title": "ACTS Code Review Interface",
  "type": "object",
  "required": [
    "acts_version",
    "interface_version",
    "required_methods",
    "required_outputs",
    "default_provider",
    "providers"
  ],
  "properties": {
    "acts_version": {
      "type": "string",
      "description": "ACTS specification version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["0.4.0"]
    },
    "interface_version": {
      "type": "string",
      "description": "Code review interface version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "required_methods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "check",
          "serve",
          "status",
          "export"
        ]
      },
      "description": "Methods that providers MUST implement"
    },
    "required_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "review_status",
          "review_comments",
          "review_export"
        ]
      },
      "description": "Outputs that providers MUST produce"
    },
    "default_provider": {
      "type": "string",
      "description": "Default provider to use if not specified"
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["config", "cli"],
        "properties": {
          "config": {
            "type": "string",
            "description": "Path to provider configuration file"
          },
          "cli": {
            "type": "string",
            "description": "CLI command name"
          },
          "min_version": {
            "type": "string",
            "description": "Minimum required version"
          }
        }
      }
    }
  }
}
