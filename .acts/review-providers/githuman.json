{
  "provider": "githuman",
  "cli": "githuman",
  "min_version": "0.6.0",
  "commands": {
    "check": {
      "cmd": "githuman",
      "args": ["--version"],
      "description": "Verify GitHuman is installed"
    },
    "serve": {
      "cmd": "githuman",
      "args": ["serve", "--port", "{port}", "--no-open"],
      "description": "Start review server",
      "options": {
        "port": {
          "default": 3847,
          "description": "Port for review server"
        },
        "auto_open": {
          "default": false,
          "description": "Auto-open browser"
        }
      }
    },
    "status": {
      "cmd": "githuman",
      "args": ["list", "--status", "--json"],
      "description": "Get review status"
    },
    "export": {
      "cmd": "githuman",
      "args": ["export", "last", "--output", "{output_path}"],
      "description": "Export review to file",
      "options": {
        "output_path": {
          "required": true,
          "description": "Path to export review"
        }
      }
    }
  },
  "exit_codes": {
    "0": "success",
    "1": "error",
    "2": "review_changes_requested"
  },
  "export_format": "markdown",
  "review_status_values": [
    "in_progress",
    "approved",
    "changes_requested"
  ]
}
