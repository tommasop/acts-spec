{
  "provider": "critique",
  "cli": "critique",
  "install": "bun install -g critique",
  "min_version": "0.1.139",
  "commands": {
    "check": {
      "cmd": "bunx",
      "args": ["critique", "--version"],
      "description": "Verify critique is installed"
    },
    "review": {
      "cmd": "bunx",
      "args": ["critique", "--staged"],
      "description": "Launch TUI for interactive code review of staged changes. Human reviews diffs, then tells agent the result.",
      "behavior": "interactive_tui"
    }
  },
  "exit_codes": {
    "0": "review_complete",
    "1": "error"
  },
  "export_format": "markdown",
  "review_status_values": [
    "approved",
    "changes_requested"
  ]
}
