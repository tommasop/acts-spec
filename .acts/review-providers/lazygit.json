{
  "provider": "lazygit",
  "cli": "lazygit",
  "install": "brew install lazygit",
  "min_version": "0.40.0",
  "commands": {
    "check": {
      "cmd": "lazygit",
      "args": ["--version"],
      "description": "Verify lazygit is installed"
    },
    "review": {
      "cmd": "lazygit",
      "args": [],
      "description": "Launch lazygit TUI. Navigate to staged changes to review diffs. Human reviews interactively, then tells agent the result.",
      "behavior": "interactive_tui"
    }
  },
  "exit_codes": {
    "0": "review_complete",
    "1": "error"
  },
  "export_format": "markdown",
  "review_status_values": [
    "approved",
    "changes_requested"
  ]
}
