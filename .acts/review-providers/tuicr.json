{
  "provider": "tuicr",
  "cli": "tuicr",
  "install": "cargo install tuicr",
  "min_version": "0.9.0",
  "commands": {
    "check": {
      "cmd": "tuicr",
      "args": ["--version"],
      "description": "Verify tuicr is installed"
    },
    "review": {
      "cmd": "tuicr",
      "args": ["--stdout"],
      "description": "Launch TUI for interactive code review. Blocks until review is complete. Outputs structured Markdown to stdout.",
      "behavior": "blocking_stdout"
    }
  },
  "exit_codes": {
    "0": "review_complete",
    "1": "error"
  },
  "export_format": "markdown",
  "review_status_values": [
    "approved",
    "changes_requested"
  ]
}
